# AI Gift Song - Environment Variables
# Copy this file to .env and fill in your values

# ============================================
# SUNO API (Required for song generation)
# ============================================
SUNO_API_KEY=your-suno-api-key-here

# ============================================
# PAYPAL CONFIGURATION (Required for payments)
# ============================================

# PayPal Client ID from Developer Dashboard
# Sandbox: https://developer.paypal.com/
# Live: https://developer.paypal.com/
PAYPAL_CLIENT_ID=your-paypal-client-id

# PayPal Secret (only needed for server-side API calls)
PAYPAL_SECRET=your-paypal-secret

# Set to 'true' for sandbox testing, 'false' or remove for live
USE_SANDBOX=true

# ============================================
# DOWNLOAD CONFIGURATION (Required for file delivery)
# ============================================

# Base URL for download links (must be configured for actual downloads)
DOWNLOAD_BASE_URL=https://your-domain.com

# Secret for signing download URLs
DOWNLOAD_SECRET=generate-a-random-secret-string-here

# ============================================
# SONG PRICING
# ============================================
SONG_PRICE=4.99

# ============================================
# OPTIONAL CONFIGURATION
# ============================================

# Your site URL (for share links)
SITE_URL=https://your-domain.com

# Analytics tracking ID (optional)
# ANALYTICS_ID=G-XXXXXXXXXX
