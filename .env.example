# AI Gift Song - Environment Variables for Vercel Deployment
# Copy this to .env and fill in your actual values

# Suno API Key (required for song generation)
# Get your key from: https://evolink.ai/suno
SUNO_API_KEY=sk-your-suno-api-key-here

# Evolink API Key (alternative)
EVOLINK_API_KEY=sk-your-evolink-api-key-here
